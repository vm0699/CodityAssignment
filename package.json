{
  "name": "pulse-distributed-job-scheduler",
  "version": "1.0.0",
  "private": true,
  "description": "Pulse — a production-inspired distributed job scheduling platform (Codity intern assignment)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @pulse/api",
    "dev:worker": "npm run dev -w @pulse/worker",
    "dev:scheduler": "npm run dev -w @pulse/scheduler",
    "dev:web": "npm run dev -w @pulse/web",
    "migrate": "npm run migrate -w @pulse/core",
    "seed": "npm run seed -w @pulse/core",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build:web": "npm run build -w @pulse/web"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
