# --- Database ---
DATABASE_URL=postgres://pulse:pulse@localhost:5433/pulse
# Used by integration tests (a separate throwaway database)
TEST_DATABASE_URL=postgres://pulse:pulse@localhost:5433/pulse_test

# --- API ---
API_PORT=4000
JWT_SECRET=change-me-in-production-9f8e7d6c5b4a
JWT_EXPIRES_IN=24h
# requests per minute per user/IP (token bucket)
RATE_LIMIT_PER_MINUTE=300
CORS_ORIGIN=http://localhost:5173

# --- Worker ---
# how many jobs a single worker process runs concurrently
WORKER_CONCURRENCY=5
# base poll interval in ms (LISTEN/NOTIFY wakes workers sooner)
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000
# a worker missing heartbeats for this long is considered dead; its jobs get requeued
WORKER_LEASE_TIMEOUT_MS=30000

# --- Scheduler ---
SCHEDULER_TICK_MS=1000

# --- Optional: AI failure summaries (falls back to rule-based summaries when unset) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Web (Vite) ---
VITE_API_URL=http://localhost:4000
